{
  "name": "pi-zai-usage",
  "version": "0.1.0",
  "description": "Z.ai API quota monitor extension for pi-coding-agent",
  "keywords": [
    "pi-package"
  ],
  "files": [
    "src/**/*.ts",
    "!src/__tests__/**",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "main": "src/index.ts",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.0.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "author": "harms-haus",
  "engines": {
    "node": ">=20.0.0"
  }
}
